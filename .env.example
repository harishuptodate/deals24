
# Environment variables for Docker deployment

# Frontend Environment Variables
VITE_API_BASE_URL=http://localhost:3000/api
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=your_admin_password

# Backend Environment Variables
NODE_ENV=production
PORT=3000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/deals24?retryWrites=true&w=majority
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=your_channel_id
WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook
REDIS_URL=redis://redis:6379
JWT_SECRET=your_jwt_secret_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_AUTH_SECRET=replace_with_a_long_random_secret
ADMIN_LOG_PERSIST_LEVEL=warn
ADMIN_LOG_STREAM_LEVEL=info
ADMIN_LOG_RECENT_LIMIT=300
CORS_ALLOWED_ORIGINS=http://localhost:8080,https://yourdomain.com
IS_SALE_MODE=false
