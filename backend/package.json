{
  "name": "deals24-backend",
  "version": "1.0.0",
  "description": "Backend for Deals24 Telegram message aggregator",
  "main": "dist/index.js",
  "scripts": {
    "build": "node ../node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "dev": "npm run build && nodemon dist/index.js",
    "typecheck": "node ../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "lint": "node ../node_modules/eslint/bin/eslint.js . --config eslint.config.js",
    "test": "npm run build && node --test dist/utils/extractPrice.test.js dist/services/telegramMessageFilters.test.js"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "axios": "^1.8.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.6.1",
    "mongoose": "^7.6.3",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^7.0.1",
    "telegraf": "^4.15.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
